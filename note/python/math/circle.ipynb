    "import plotly.express as px\n",
    "import numpy as np\n",
    "t = np.linspace(0, 2*np.pi)\n",
    "x = np.cos(t)\n",
    "y = np.sin(t)\n",
    "\n",
    "fig = px.scatter(x=x, y=y)\n",
    "fig.layout.yaxis.scaleanchor=\"x\"\n",
    "fig.show()"
   ]
