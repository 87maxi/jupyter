						"method": "WEBSOCKET",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": 1, \n  \"method\": \"eth_subscribe\", \n  \"params\": [\n    \"logs\", \n    {\n      \"address\": \"0x0000000000000000000000000000000000000000\",\n      \"topics\": []\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{ws_host}}",
							"protocol": "wss",
							"host": [
								"{{ws_host}}"
							]
						},
						"description": "Subscribes to event logs. You can filter by address and topics. The example shows a generic filter; modify the address and topics to match your needs. You need to send this JSON payload over an active WebSocket connection."
