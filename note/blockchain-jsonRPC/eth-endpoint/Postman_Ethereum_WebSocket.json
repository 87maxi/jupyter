			"name": "Subscriptions",
			"item": [
				{
					"name": "newHeads",
					"request": {
						"method": "WEBSOCKET",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": 1, \n  \"method\": \"eth_subscribe\", \n  \"params\": [\"newHeads\"]\n}"
						},
						"url": {
							"raw": "{{ws_host}}",
							"protocol": "wss",
							"host": [
								"{{ws_host}}"
							]
						},
						"description": "Subscribes to new block headers. This will send a notification for each new block. You need to send this JSON payload over an active WebSocket connection."
					},
					"response": []
				},
				{
					"name": "logs",
