							"raw": "{\"jsonrpc\":\"2.0\",\"method\":\"eth_getBlockByNumber\",\"params\":[\"safe\", true],\"id\":1}"
						},
						"url": {
							"raw": "{{host}}",
							"host": [
								"{{host}}"
							]
						},
						"description": "Returns information about the latest block that has been accepted by a supermajority of validators. It is less likely to be reorganized than 'latest' but can still be reverted in favor of a competing 'safe' block."
					},
					"response": []
				},
