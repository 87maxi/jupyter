		{
			"name": "The Merge",
			"item": [
				{
					"name": "eth_getBlockByNumber (The Merge)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"jsonrpc\":\"2.0\",\"method\":\"eth_getBlockByNumber\",\"params\":[\"latest\", false],\"id\":1}"
						},
						"url": {
							"raw": "{{host}}",
							"host": [
								"{{host}}"
							]
						},
						"description": "Returns information about a block by block number. After The Merge, the `difficulty` field is replaced by `prevRandao` (via EIP-4399), and `mixHash` is also related. The `totalDifficulty` is now a fixed value. Uncles are no longer produced, so `uncles` will be an empty array."
					},
					"response": []
				},
				{
					"name": "eth_getBlockByNumber (Finalized)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"jsonrpc\":\"2.0\",\"method\":\"eth_getBlockByNumber\",\"params\":[\"finalized\", true],\"id\":1}"
						},
						"url": {
							"raw": "{{host}}",
							"host": [
								"{{host}}"
							]
						},
						"description": "Returns information about the latest block that has been finalized by the consensus layer. Using the 'finalized' tag ensures you are querying state that is highly unlikely to be reverted."
					},
					"response": []
				},
				{
					"name": "eth_getBlockByNumber (Safe)",
					"request": {
						"method": "POST",
						"header": [
